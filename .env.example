# ============================================================
# Content Zavod — example configuration
# Copy to .env and fill in your own values. Never commit .env.
# ============================================================

# --- Telegram (required) ---
# Get your bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# --- Database ---
# SQLite by default. For production you can use PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/content_zavod
DATABASE_URL=sqlite+aiosqlite:///./content_zavod.db

# --- AI image provider: "openai" or "kie" ---
# Chooses which backend generates images. Text generation always uses the
# OpenAI-compatible client below.
AI_PROVIDER=openai

# --- OpenAI (required) ---
# Used for text generation, voice transcription and image understanding always,
# and for image generation when AI_PROVIDER=openai.
OPENAI_API_KEY=sk-...
# Optional: any OpenAI-compatible endpoint (proxy / self-hosted / another provider)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Text model (any chat-completions model available on OPENAI_BASE_URL)
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.7

# Voice transcription + image understanding models (always via OpenAI)
# OPENAI_TRANSCRIBE_MODEL=whisper-1
# OPENAI_VISION_MODEL=gpt-4o-mini

# OpenAI image model when AI_PROVIDER=openai ("gpt-image-1" or "dall-e-3")
# OPENAI_IMAGE_MODEL=gpt-image-1

# --- Kie.ai (only needed when AI_PROVIDER=kie) ---
# Get your API key at https://kie.ai
KIE_API_KEY=
# KIE_BASE_URL=https://api.kie.ai
# Image model slug, e.g. "google/nano-banana"
# KIE_IMAGE_MODEL=google/nano-banana

# Image aspect / size: 1024x1024 | 1792x1024 | 1024x1792
# IMAGE_SIZE=1024x1024

# --- Timezone ---
DEFAULT_TIMEZONE=Europe/Moscow

# --- Scheduler / parser tuning (seconds) ---
# 300-600 is recommended for the post scheduler; lower adds noise with no benefit.
SCHEDULER_INTERVAL=300
PARSER_DELAY=2

# Note: YouTube transcripts use the free youtube-transcript-api (no API key needed).
